## Key commands reference

```bash
# QC
fastqc sample_R1.fastq sample_R2.fastq -o qc_output/
multiqc qc_output/ -o multiqc_report/

# Trim
fastp -i R1.fq -I R2.fq -o out_R1.fq -O out_R2.fq --detect_adapter_for_pe

# Align (RNA-seq)
hisat2 -x genome_index -1 R1.fq -2 R2.fq -S out.sam -p 8

# SAM to BAM
samtools view -bS out.sam | samtools sort -o sorted.bam
samtools index sorted.bam
samtools flagstat sorted.bam

# Variant calling
gatk HaplotypeCaller -R ref.fa -I sorted.bam -O variants.vcf

# Count reads
featureCounts -a genes.gtf -o counts.txt sorted.bam

# Annotation
snpEff ann genome variants.vcf > annotated.vcf
```

